<!-- src/apps/sparqlstore-to-site-indexes/templates/index-html.njk -->
<!DOCTYPE html>
<html lang="en">

<head>
    <title>Rawer - Recent Articles</title>

    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <meta name="description" content="Recent articles from the knowledge base">

    <link rel="alternate" type="application/atom+xml" title="Atom Feed" href="/atom.xml" />

    <!-- TODO: remove cache-control headers once the generated indexes are stable. -->
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
    <meta http-equiv="Pragma" content="no-cache">
    <meta http-equiv="Expires" content="0">

    <link rel="stylesheet" href="/css/fonts.css" type="text/css" />
    <link rel="stylesheet" href="/css/grid-columns.css" type="text/css" />
    <link rel="stylesheet" href="/css/style.css" type="text/css" />

    <style>
        :root {
            --index-bg: #f7f7f4;
            --index-panel: #fff;
            --index-text: #042f2f;
            --index-muted: #66736f;
            --index-line: #d9ddd7;
            --index-accent: #b94f24;
            --index-shadow: 0 8px 24px rgba(4, 47, 47, 0.08);
        }

        body {
            background: var(--index-bg);
            color: var(--index-text);
        }

        body.menu-open {
            overflow: hidden;
        }

        .site-header,
        .site-menu,
        .index-shell,
        .article-list-item {
            box-sizing: border-box;
        }

        .site-header {
            position: sticky;
            top: 0;
            z-index: 20;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            max-width: 58rem;
            margin: 0 auto;
            padding: 1rem clamp(1rem, 4vw, 2rem);
            background: rgba(247, 247, 244, 0.94);
            backdrop-filter: blur(8px);
            border-bottom: 1px solid var(--index-line);
        }

        .h-title {
            margin: 0;
            font-size: clamp(1.35rem, 5vw, 1.9rem);
        }

        .site-menu-toggle {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 2.75rem;
            height: 2.75rem;
            flex: 0 0 auto;
            border: 1px solid var(--index-line);
            border-radius: 8px;
            background: var(--index-panel);
            color: var(--index-text);
            cursor: pointer;
            box-shadow: 0 2px 10px rgba(4, 47, 47, 0.08);
        }

        .menu-bars {
            position: relative;
            width: 1.35rem;
            height: 1rem;
        }

        .menu-bars span {
            position: absolute;
            left: 0;
            width: 100%;
            height: 2px;
            background: currentColor;
            transition: transform 0.2s ease, opacity 0.2s ease;
        }

        .menu-bars span:nth-child(1) {
            top: 0;
        }

        .menu-bars span:nth-child(2) {
            top: 0.45rem;
        }

        .menu-bars span:nth-child(3) {
            bottom: 0;
        }

        .site-menu-toggle[aria-expanded="true"] .menu-bars span:nth-child(1) {
            transform: translateY(0.45rem) rotate(45deg);
        }

        .site-menu-toggle[aria-expanded="true"] .menu-bars span:nth-child(2) {
            opacity: 0;
        }

        .site-menu-toggle[aria-expanded="true"] .menu-bars span:nth-child(3) {
            transform: translateY(-0.45rem) rotate(-45deg);
        }

        .site-menu-overlay {
            position: fixed;
            inset: 0;
            z-index: 30;
            background: rgba(4, 47, 47, 0.32);
            opacity: 0;
            visibility: hidden;
            transition: opacity 0.2s ease, visibility 0.2s ease;
        }

        .site-menu {
            position: fixed;
            top: 0;
            right: 0;
            bottom: 0;
            z-index: 40;
            width: min(22rem, calc(100vw - 1.5rem));
            padding: 5rem 1rem 1.5rem;
            overflow-y: auto;
            background: var(--index-panel);
            box-shadow: -12px 0 32px rgba(4, 47, 47, 0.14);
            transform: translateX(100%);
            visibility: hidden;
            transition: transform 0.22s ease, visibility 0.22s ease;
        }

        .site-menu.is-open {
            transform: translateX(0);
            visibility: visible;
        }

        .site-menu-overlay.is-open {
            opacity: 1;
            visibility: visible;
        }

        .site-menu a {
            display: block;
            min-height: 2.75rem;
            padding: 0.7rem 0.25rem;
            color: var(--index-text);
            text-decoration: none;
            border-bottom: 1px solid var(--index-line);
        }

        .site-menu a:hover,
        .site-menu a:focus-visible {
            color: var(--index-accent);
        }

        .site-menu-title {
            margin: 0 0 0.8rem;
            font-family: 'cinzel', sans-serif;
            font-size: 1rem;
            letter-spacing: 0;
        }

        .index-shell {
            width: min(100%, 58rem);
            margin: 0 auto;
            padding: 1.25rem clamp(1rem, 4vw, 2rem) 3rem;
        }

        .index-intro {
            margin: 0 0 1rem;
            color: var(--index-muted);
        }

        .articles {
            display: grid;
            gap: 1rem;
            max-width: none;
            margin: 0;
        }

        .article-list-item {
            margin: 0;
            padding: clamp(1rem, 3vw, 1.5rem);
            background: var(--index-panel);
            border: 1px solid var(--index-line);
            border-radius: 8px;
            box-shadow: var(--index-shadow);
        }

        .article-list-item h2 {
            margin: 0 0 0.45rem;
            font-size: clamp(1.25rem, 4vw, 1.6rem);
            line-height: 1.25;
        }

        .article-list-item h2 a {
            color: inherit;
            text-decoration-thickness: 0.08em;
            text-underline-offset: 0.14em;
        }

        .article-meta {
            color: var(--index-muted);
            font-size: 0.92rem;
            margin-bottom: 1rem;
        }

        .article-content {
            overflow-wrap: anywhere;
        }

        .article-content .post-content > h1:first-child,
        .article-content .post-title {
            display: none;
        }

        .article-content img,
        .article-content video,
        .article-content iframe {
            max-width: 100%;
            height: auto;
        }

        .article-content pre,
        .article-content table {
            max-width: 100%;
            overflow-x: auto;
        }

        .empty-index {
            padding: 1.5rem;
            background: var(--index-panel);
            border: 1px solid var(--index-line);
            border-radius: 8px;
        }

        @media (max-width: 640px) {
            .site-header {
                padding: 0.75rem 0.9rem;
            }

            .index-shell {
                padding: 1rem 0.75rem 2rem;
            }

            .site-menu {
                width: min(100vw, 24rem);
            }

            .article-list-item {
                border-radius: 6px;
            }
        }
    </style>
</head>

<body>
    <header id="main-header" class="site-header">
        <h1 class="h-title">Raw<em>er</em></h1>
        <button class="site-menu-toggle" type="button" aria-label="Open navigation menu" aria-controls="site-menu" aria-expanded="false">
            <span class="menu-bars" aria-hidden="true">
                <span></span>
                <span></span>
                <span></span>
            </span>
        </button>
    </header>

    <div class="site-menu-overlay" data-menu-close></div>
    <nav id="site-menu" class="site-menu" aria-label="Site links">
        <p class="site-menu-title">Links</p>
        <a href="#recent">Recent articles</a>
        <a href="/atom.xml">Atom feed</a>
    </nav>

    <main class="index-shell">
        <p class="index-intro">Recent articles from the knowledge base.</p>
        <section id="recent" class="articles" aria-label="Recent articles">
            {% if contentBlocks.content %}
                {% for article in contentBlocks.content %}
                <article class="article-list-item">
                    <h2>
                        {% if article.uri %}
                        <a href="{{ article.uri }}">{{ article.title }}</a>
                        {% else %}
                        {{ article.title }}
                        {% endif %}
                    </h2>
                    {% if article.published %}
                    <div class="article-meta">
                        Published: {{ article.published }}
                    </div>
                    {% endif %}
                    <div class="article-content">
                        {{ article.content | safe }}
                    </div>
                </article>
                {% endfor %}
            {% else %}
                <p class="empty-index">No recent articles available.</p>
            {% endif %}
        </section>
    </main>

    <script>
        const menuButton = document.querySelector('.site-menu-toggle');
        const menu = document.querySelector('#site-menu');
        const overlay = document.querySelector('[data-menu-close]');
        const links = menu.querySelectorAll('a');

        const setMenu = (isOpen) => {
            document.body.classList.toggle('menu-open', isOpen);
            menu.classList.toggle('is-open', isOpen);
            overlay.classList.toggle('is-open', isOpen);
            menuButton.setAttribute('aria-expanded', String(isOpen));
            menuButton.setAttribute('aria-label', isOpen ? 'Close navigation menu' : 'Open navigation menu');
        };

        menuButton.addEventListener('click', () => {
            setMenu(menuButton.getAttribute('aria-expanded') !== 'true');
        });

        overlay.addEventListener('click', () => setMenu(false));

        links.forEach((link) => {
            link.addEventListener('click', () => setMenu(false));
        });

        document.addEventListener('keydown', (event) => {
            if (event.key === 'Escape') {
                setMenu(false);
            }
        });
    </script>
</body>

</html>
