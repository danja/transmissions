<!DOCTYPE html>
<html lang="en">

<head>
    <title>Rawer - Archive</title>

    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <meta name="description" content="Article archive from the knowledge base">

    <link rel="alternate" type="application/atom+xml" title="Atom Feed" href="/atom.xml" />
    <link rel="stylesheet" href="/css/fonts.css" type="text/css" />
    <link rel="stylesheet" href="/css/style.css" type="text/css" />

    <style>
        :root {
            --archive-bg: #f7f7f4;
            --archive-panel: #fff;
            --archive-text: #042f2f;
            --archive-muted: #66736f;
            --archive-line: #d9ddd7;
            --archive-accent: #b94f24;
        }

        body {
            background: var(--archive-bg);
            color: var(--archive-text);
        }

        body.menu-open {
            overflow: hidden;
        }

        .site-header,
        .site-menu,
        .archive-shell,
        .archive-list a {
            box-sizing: border-box;
        }

        .site-header {
            position: sticky;
            top: 0;
            z-index: 20;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            max-width: 58rem;
            margin: 0 auto;
            padding: 1rem clamp(1rem, 4vw, 2rem);
            background: rgba(247, 247, 244, 0.94);
            backdrop-filter: blur(8px);
            border-bottom: 1px solid var(--archive-line);
        }

        .h-title {
            margin: 0;
            font-size: clamp(1.35rem, 5vw, 1.9rem);
        }

        .site-menu-toggle {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 2.75rem;
            height: 2.75rem;
            flex: 0 0 auto;
            border: 1px solid var(--archive-line);
            border-radius: 8px;
            background: var(--archive-panel);
            color: var(--archive-text);
            cursor: pointer;
        }

        .menu-bars {
            position: relative;
            width: 1.35rem;
            height: 1rem;
        }

        .menu-bars span {
            position: absolute;
            left: 0;
            width: 100%;
            height: 2px;
            background: currentColor;
            transition: transform 0.2s ease, opacity 0.2s ease;
        }

        .menu-bars span:nth-child(1) {
            top: 0;
        }

        .menu-bars span:nth-child(2) {
            top: 0.45rem;
        }

        .menu-bars span:nth-child(3) {
            bottom: 0;
        }

        .site-menu-toggle[aria-expanded="true"] .menu-bars span:nth-child(1) {
            transform: translateY(0.45rem) rotate(45deg);
        }

        .site-menu-toggle[aria-expanded="true"] .menu-bars span:nth-child(2) {
            opacity: 0;
        }

        .site-menu-toggle[aria-expanded="true"] .menu-bars span:nth-child(3) {
            transform: translateY(-0.45rem) rotate(-45deg);
        }

        .site-menu-overlay {
            position: fixed;
            inset: 0;
            z-index: 30;
            background: rgba(4, 47, 47, 0.32);
            opacity: 0;
            visibility: hidden;
            transition: opacity 0.2s ease, visibility 0.2s ease;
        }

        .site-menu {
            position: fixed;
            top: 0;
            right: 0;
            bottom: 0;
            z-index: 40;
            width: min(22rem, calc(100vw - 1.5rem));
            padding: 5rem 1rem 1.5rem;
            overflow-y: auto;
            background: var(--archive-panel);
            box-shadow: -12px 0 32px rgba(4, 47, 47, 0.14);
            transform: translateX(100%);
            visibility: hidden;
            transition: transform 0.22s ease, visibility 0.22s ease;
        }

        .site-menu.is-open {
            transform: translateX(0);
            visibility: visible;
        }

        .site-menu-overlay.is-open {
            opacity: 1;
            visibility: visible;
        }

        .site-menu a {
            display: block;
            min-height: 2.75rem;
            padding: 0.7rem 0.25rem;
            color: var(--archive-text);
            text-decoration: none;
            border-bottom: 1px solid var(--archive-line);
        }

        .site-menu-title {
            margin: 0 0 0.8rem;
            font-family: 'cinzel', sans-serif;
            font-size: 1rem;
        }

        .archive-shell {
            width: min(100%, 58rem);
            margin: 0 auto;
            padding: 1.25rem clamp(1rem, 4vw, 2rem) 3rem;
        }

        .archive-heading {
            margin: 0 0 0.35rem;
            font-size: clamp(1.5rem, 5vw, 2rem);
        }

        .archive-intro {
            margin: 0 0 1.25rem;
            color: var(--archive-muted);
        }

        .archive-list {
            display: grid;
            gap: 0.5rem;
            margin: 0;
            padding: 0;
            list-style: none;
        }

        .archive-list a {
            display: grid;
            grid-template-columns: minmax(8.5rem, 12rem) 1fr;
            gap: 1rem;
            min-width: 0;
            min-height: 3rem;
            align-items: baseline;
            padding: 0.8rem 1rem;
            background: var(--archive-panel);
            border: 1px solid var(--archive-line);
            border-radius: 8px;
            color: var(--archive-text);
            text-decoration: none;
        }

        .archive-list a:hover,
        .archive-list a:focus-visible {
            border-color: var(--archive-accent);
        }

        .archive-date {
            min-width: 0;
            color: var(--archive-muted);
            font-size: 0.92rem;
            font-variant-numeric: tabular-nums;
            overflow-wrap: anywhere;
        }

        .archive-title {
            min-width: 0;
            font-weight: 700;
            overflow-wrap: anywhere;
        }

        .empty-archive {
            padding: 1.5rem;
            background: var(--archive-panel);
            border: 1px solid var(--archive-line);
            border-radius: 8px;
        }

        @media (max-width: 640px) {
            .site-header {
                padding: 0.75rem 0.9rem;
            }

            .archive-shell {
                padding: 1rem 0.75rem 2rem;
            }

            .site-menu {
                width: min(100vw, 24rem);
            }

            .archive-list a {
                grid-template-columns: 1fr;
                gap: 0.15rem;
                padding: 0.85rem;
            }
        }
    </style>
</head>

<body>
    {% set articles = entries or content %}
    <header id="main-header" class="site-header">
        <h1 class="h-title">Raw<em>er</em></h1>
        <button class="site-menu-toggle" type="button" aria-label="Open navigation menu" aria-controls="site-menu" aria-expanded="false">
            <span class="menu-bars" aria-hidden="true">
                <span></span>
                <span></span>
                <span></span>
            </span>
        </button>
    </header>

    <div class="site-menu-overlay" data-menu-close></div>
    <nav id="site-menu" class="site-menu" aria-label="Site links">
        <p class="site-menu-title">Links</p>
        <a href="/">Recent articles</a>
        <a href="/archive.html">Archive</a>
        <a href="/atom.xml">Atom feed</a>
    </nav>

    <main class="archive-shell">
        <h2 class="archive-heading">Archive</h2>
        <p class="archive-intro">{{ articles | length }} articles, newest first.</p>
        {% if articles and (articles | length) %}
        <ol class="archive-list">
            {% for article in articles %}
            <li>
                <a href="{{ article.uri }}">
                    <span class="archive-date">{{ article.published }}</span>
                    <span class="archive-title">{{ article.title }}</span>
                </a>
            </li>
            {% endfor %}
        </ol>
        {% else %}
        <p class="empty-archive">No articles available.</p>
        {% endif %}
    </main>

    <script>
        const menuButton = document.querySelector('.site-menu-toggle');
        const menu = document.querySelector('#site-menu');
        const overlay = document.querySelector('[data-menu-close]');
        const links = menu.querySelectorAll('a');

        const setMenu = (isOpen) => {
            document.body.classList.toggle('menu-open', isOpen);
            menu.classList.toggle('is-open', isOpen);
            overlay.classList.toggle('is-open', isOpen);
            menuButton.setAttribute('aria-expanded', String(isOpen));
            menuButton.setAttribute('aria-label', isOpen ? 'Close navigation menu' : 'Open navigation menu');
        };

        menuButton.addEventListener('click', () => {
            setMenu(menuButton.getAttribute('aria-expanded') !== 'true');
        });

        overlay.addEventListener('click', () => setMenu(false));

        links.forEach((link) => {
            link.addEventListener('click', () => setMenu(false));
        });

        document.addEventListener('keydown', (event) => {
            if (event.key === 'Escape') {
                setMenu(false);
            }
        });
    </script>
</body>

</html>
